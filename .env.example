# ============================================
# Kisaan Saathi - Environment Variables
# ============================================
# Copy this file to .env and fill in your API keys
# cp .env.example .env

# ------ REQUIRED API KEYS ------

# Groq API Key (for disease detection LLM + Farmer Assistant)
# Get it from: https://console.groq.com/keys (free tier available)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (for Government Schemes chatbot)
# Get it from: https://aistudio.google.com/apikey (free tier available)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeatherMap API Key (for weather advisory)
# Get it from: https://home.openweathermap.org/api_keys (free tier available)
OPEN_WEATHER_API_KEY=your_openweather_api_key_here

# Data.gov.in API Key (for market price data)
# Get it from: https://data.gov.in/user/register (free, Indian govt portal)
DATA_GOV_API_KEY=your_data_gov_api_key_here

# ------ OPTIONAL API KEYS ------

# Perplexity API Key (for web search in farmer assistant)
# Get it from: https://www.perplexity.ai/settings/api
TAVILY_API_KEY=your_tavily_api_key_here

# ------ APPLICATION SETTINGS ------
APP_HOST=127.0.0.1
APP_PORT=8000
APP_SECRET_KEY=change-this-to-a-random-secret-key-for-sessions
